{
  "name": "apimo.js",
  "version": "1.1.0",
  "description": "A wrapper for the Apimo API with catalog caching for building custom Real Estate website using their technologies.",
  "author": "Vitaly Lysen <vitaly@lysen.dev> (https://lysen.dev)",
  "license": "MIT",
  "homepage": "https://github.com/Neikow/apimo.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/Neikow/apimo.js.git"
  },
  "bugs": {
    "url": "https://github.com/Neikow/apimo.js/issues"
  },
  "keywords": [
    "api",
    "apimo",
    "real-estate"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "LICENSE",
    "README.md",
    "dist/**/*"
  ],
  "scripts": {
    "dev": "",
    "build": "tsc",
    "run": "node dist/index.js",
    "test": "vitest run",
    "test-coverage": "vitest run --coverage",
    "lint": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "prepare": "husky"
  },
  "peerDependencies": {
    "better-sqlite3": "^12.0.0",
    "pg": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  },
  "dependencies": {
    "bottleneck": "^2.19.5",
    "merge-anything": "^6.0.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@anatine/zod-mock": "^3.14.0",
    "@antfu/eslint-config": "^7.2.0",
    "@faker-js/faker": "^10.2.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.1.0",
    "@types/pg": "^8.18.0",
    "@vitest/coverage-v8": "^4.0.18",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.2.1",
    "eslint": "^9.32.0",
    "husky": "^9.1.7",
    "pg": "^8.19.0",
    "typescript": "^5.9.2",
    "vitest": "^4.0.18"
  }
}
